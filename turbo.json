{
    "$schema": "node_modules/turbo/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "lib/**", ".output/**"],
            "cache": true
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "outputs": ["dist"]
        }
    }
}
