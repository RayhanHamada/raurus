{
    "$schema": "node_modules/turbo/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "lib/**", ".output/**", ".next/**"],
            "cache": true
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "outputs": ["dist"]
        }
    }
}
