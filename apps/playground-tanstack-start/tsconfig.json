{
    "extends": ["@raurus/tsconfig"],
    "include": ["**/*.ts", "**/*.tsx"],
    "compilerOptions": {
        "jsx": "react-jsx",
        "paths": {
            "#/*": ["./src/*"],
            "@/*": ["./src/*"]
        },
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "types": ["vite/client"],

        /* Bundler mode */
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,

        /* Linting */
        "skipLibCheck": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true
    }
}
