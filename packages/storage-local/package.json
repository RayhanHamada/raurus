{
    "name": "@raurus/storage-local",
    "version": "0.0.0",
    "description": "Local filesystem storage adapter for Raurus",
    "license": "MIT",
    "author": "Muhammad Rayhan Hamada Budiman <rayhanhamada1999@gmail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/RayhanHamada/raurus.git"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "exports": {
        ".": "./dist/index.mjs",
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "typecheck": "tsc --noEmit",
        "release": "bumpp"
    },
    "dependencies": {
        "@raurus/core": "workspace:*",
        "@raurus/logger": "workspace:*"
    },
    "devDependencies": {
        "@raurus/tsconfig": "workspace:*",
        "@types/node": "^25.6.2",
        "bumpp": "^11.1.0",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.3"
    }
}
