{
    "name": "@raurus/react",
    "version": "0.0.0",
    "description": "Raurus React package",
    "homepage": "https://github.com/rayhanhamada/raurus#readme",
    "bugs": {
        "url": "https://github.com/rayhanhamada/raurus/issues"
    },
    "license": "MIT",
    "author": "Rayhan Hamada <rayhanhamada@gmail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rayhanhamada/raurus.git"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "exports": {
        "./client": "./dist/client.js",
        "./server": "./dist/server.js",
        "./package.json": "./package.json",
        "./style.css": "./dist/style.css"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "play": "vite",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "release": "bumpp",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@raurus/client": "workspace:*",
        "cnfast": "^0.0.8"
    },
    "devDependencies": {
        "@bosh-code/tsdown-plugin-inject-css": "^2.0.0",
        "@bosh-code/tsdown-plugin-tailwindcss": "^1.0.1",
        "@chromatic-com/storybook": "^5.2.1",
        "@raurus/tsconfig": "workspace:*",
        "@storybook/addon-mcp": "^0.6.0",
        "@storybook/addon-vitest": "^10.4.6",
        "@storybook/react-vite": "^10.4.6",
        "@tailwindcss/vite": "^4.3.2",
        "@tsconfig/strictest": "^2.0.8",
        "@types/node": "^26.0.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/browser-playwright": "^4.1.9",
        "@vitest/coverage-v8": "4.1.9",
        "bumpp": "^11.1.0",
        "mockdate": "^3.0.5",
        "msw": "^2.14.6",
        "msw-storybook-addon": "^2.0.7",
        "playwright": "^1.61.1",
        "storybook": "^10.4.6",
        "tailwindcss": "^4.3.1",
        "tsdown": "^0.22.3",
        "typescript": "^6.0.3",
        "vite": "^8.1.0",
        "vitest": "^4.1.9",
        "vitest-browser-react": "^2.2.0"
    },
    "peerDependencies": {
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
}
