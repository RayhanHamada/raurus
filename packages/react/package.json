        "@tsconfig/strictest": "^2.0.8",
        "@types/node": "^25.6.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/browser-playwright": "^4.1.5",
        "babel-plugin-react-compiler": "^1.0.0",
        "bumpp": "^11.1.0",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.11",
        "vitest": "^4.1.5",
