{
    "name": "@raurus/react",
    "version": "0.0.0",
    "description": "React 19 visual editing component library for Raurus.",
    "homepage": "https://github.com/RayhanHamada/raurus#readme",
    "bugs": {
        "url": "https://github.com/RayhanHamada/raurus/issues"
