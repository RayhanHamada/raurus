{
    "extends": "@raurus/tsconfig",
    "compilerOptions": {
        "target": "esnext",
        "jsx": "react-jsx",
        "lib": ["es2023", "DOM"],
        "moduleDetection": "force",
        "module": "preserve",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "types": [],
        "declaration": true,
        "emitDeclarationOnly": true,
        "verbatimModuleSyntax": true,
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src"]
}
