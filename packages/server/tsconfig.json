{
    "extends": ["@raurus/tsconfig"],
    "compilerOptions": {
        "target": "esnext",
        "lib": ["ES2023", "DOM"],
        "types": ["node"],
        "rewriteRelativeImportExtensions": true,
        "allowImportingTsExtensions": true,
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src", "tsdown.config.ts"]
}
