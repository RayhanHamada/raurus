{
    "name": "@raurus/server",
    "version": "0.0.0",
    "description": "A starter for creating a TypeScript package.",
    "homepage": "https://github.com/author/library#readme",
    "bugs": {
        "url": "https://github.com/author/library/issues"
    },
    "license": "MIT",
    "author": "Author Name <author.name@mail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/author/library.git"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "exports": {
        ".": "./dist/index.mjs",
        "./adapters/example-metadata-adapter": "./dist/adapters/example-metadata-adapter/index.mjs",
        "./adapters/example-storage-adapter": "./dist/adapters/example-storage-adapter/index.mjs",
        "./adapters/s3mini-storage-adapter": "./dist/adapters/s3mini-storage-adapter/index.mjs",
        "./runtime": "./dist/runtime/index.mjs",
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsdown --config-loader unrun",
        "dev": "tsdown --watch",
        "typecheck": "tsc --noEmit",
        "release": "bumpp"
    },
    "dependencies": {
        "@cloudflare/workers-types": "^4.20260615.1",
        "@elysia/openapi": "^1.4.15",
        "@raurus/core": "workspace:*",
        "@raurus/logger": "workspace:*",
        "elysia": "^1.4.28",
        "s3mini": "^0.9.5"
    },
    "devDependencies": {
        "@raurus/tsconfig": "workspace:*",
        "@types/node": "^25.6.2",
        "bumpp": "^11.1.0",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.3",
        "unrun": "^0.3.1",
        "vitest": "^4.1.5"
    }
}
