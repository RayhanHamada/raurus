{
    "name": "@raurus/server",
    "version": "0.0.0",
    "description": "A starter for creating a TypeScript package.",
    "homepage": "https://github.com/RayhanHamada/raurus#readme",
    "bugs": {
        "url": "https://github.com/RayhanHamada/raurus/issues"
    },
    "license": "MIT",
    "author": "Muhammad Rayhan Hamada Budiman <rayhanhamada1999@gmail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/RayhanHamada/raurus.git"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "exports": {
        ".": "./dist/index.mjs",
        "./adapters/database": "./dist/adapters/database/index.mjs",
        "./adapters/database/libsql": "./dist/adapters/database/libsql/index.mjs",
        "./adapters/storage": "./dist/adapters/storage/index.mjs",
        "./adapters/storage/s3mini": "./dist/adapters/storage/s3mini/index.mjs",
        "./runtime": "./dist/runtime/index.mjs",
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsdown --config-loader unrun",
        "dev": "tsdown --watch",
        "typecheck": "tsc --noEmit",
        "release": "bumpp"
    },
    "dependencies": {
        "@elysia/openapi": "^1.4.15",
        "@raurus/core": "workspace:*",
        "@raurus/logger": "workspace:*",
        "elysia": "^1.4.29",
        "s3mini": "^0.9.5"
    },
    "devDependencies": {
        "@raurus/tsconfig": "workspace:*",
        "@types/node": "^25.6.2",
        "bumpp": "^11.1.0",
        "tsdown": "^0.22.3",
        "typescript": "^6.0.3",
        "unrun": "^0.3.1",
        "vitest": "^4.1.5"
    },
    "peerDependencies": {
        "@cloudflare/workers-types": "^4.20260623.1",
        "@libsql/client": "^0.17.4"
    }
}
