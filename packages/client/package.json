{
    "name": "@raurus/client",
    "version": "0.0.0",
    "description": "Type-safe Raurus client SDK",
    "homepage": "https://github.com/RayhanHamada/raurus#readme",
    "bugs": {
        "url": "https://github.com/RayhanHamada/raurus/issues"
    },
    "license": "MIT",
    "author": "Muhammad Rayhan Hamada Budiman <rayhanhamada1999@gmail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/RayhanHamada/raurus.git"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsdown --config-loader unrun",
        "dev": "tsdown --watch",
        "typecheck": "tsc --noEmit",
        "release": "bumpp",
        "typegen": "bun --bun ./typegen.ts"
    },
    "dependencies": {
        "@raurus/core": "workspace:*",
        "@raurus/logger": "workspace:*",
        "openapi-fetch": "^0.17.0"
    },
    "devDependencies": {
        "@raurus/server": "workspace:*",
        "@raurus/tsconfig": "workspace:*",
        "@types/node": "^25.9.3",
        "bumpp": "^11.1.0",
        "openapi-typescript": "^7.13.0",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.3",
        "unrun": "^0.3.1",
        "vitest": "^4.1.9"
    }
}
