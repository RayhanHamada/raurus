{
    "name": "raurus",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "check": "ultracite check",
        "fix": "ultracite fix",
        "dev:docs": "bun run --cwd apps/docs dev",
        "dev:playground": "bun run --cwd apps/playground-react dev",
        "test": "turbo run test",
        "typecheck": "turbo run typecheck"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@tsconfig/strictest": "^2.0.8",
        "@types/bun": "latest",
        "@types/node": "^25.9.1",
        "oxfmt": "^0.51.0",
        "oxlint": "^1.66.0",
        "tsdown": "^0.22.0",
        "turbo": "^2.9.14",
        "typescript": "^6.0.3",
        "ultracite": "7.7.0",
        "vite": "^8.0.11",
        "vitest": "^4.1.5"
    },
    "packageManager": "bun@1.3.14"
